# Option A: direct delegated/application access token
# POWERBI_ACCESS_TOKEN=

# Option B: service principal, recommended for Claude/server automation
POWERBI_TENANT=vnu.edu.vn
POWERBI_CLIENT_ID=
POWERBI_CLIENT_SECRET=

# Optional token cache for start_device_login / complete_device_login
# POWERBI_TOKEN_CACHE=/Users/ducna/.mcp-powerbi/token-cache.json

# Optional override for the Microsoft Power BI Modeling MCP bridge.
# Defaults to: npx -y @microsoft/powerbi-modeling-mcp@latest --start
# POWERBI_MODELING_MCP_COMMAND=npx
# POWERBI_MODELING_MCP_ARGS=-y @microsoft/powerbi-modeling-mcp@latest --start
