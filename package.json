{
  "name": "mcp-powerbi-to-report",
  "version": "0.1.2",
  "description": "Claude-compatible MCP companion for Microsoft Power BI Modeling MCP with Fabric catalog discovery and HTML executive report output.",
  "type": "module",
  "bin": {
    "mcp-powerbi-to-report": "./dist/server.js",
    "mcp-powerbi-to-report-setup": "./dist/setup.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/server.ts",
    "setup": "node dist/setup.js",
    "setup:claude-desktop": "bash scripts/setup-claude-desktop.sh",
    "setup:claude-desktop:powershell": "powershell -ExecutionPolicy Bypass -File scripts/setup-claude-desktop.ps1",
    "start": "node dist/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/qlinh99/claude-mcp-powerBI-to-report.git"
  },
  "keywords": [
    "mcp",
    "powerbi",
    "report",
    "dashboard",
    "fabric",
    "semantic-model",
    "claude",
    "powerbi-modeling-mcp"
  ],
  "author": "",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/qlinh99/claude-mcp-powerBI-to-report/issues"
  },
  "homepage": "https://github.com/qlinh99/claude-mcp-powerBI-to-report#readme",
  "dependencies": {
    "@microsoft/powerbi-modeling-mcp": "0.5.0-beta.10",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
